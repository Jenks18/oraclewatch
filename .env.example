# OracleWatch Configuration
# ========================

# Polling interval in seconds (how often to check for new markets)
POLL_INTERVAL_SECONDS=5

# --- Kalshi ---
KALSHI_ENABLED=true
KALSHI_API_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# --- Polymarket ---
POLYMARKET_ENABLED=true
POLYMARKET_GAMMA_API_URL=https://gamma-api.polymarket.com

# --- Notifications ---

# Console logging (always on)
CONSOLE_NOTIFICATIONS=true

# Discord webhook
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=

# Telegram bot
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Filters (optional, comma-separated keywords) ---
# Only alert on markets matching these keywords (leave empty for all)
FILTER_KEYWORDS=

# --- Web Dashboard ---
WEB_PORT=8000

# --- Storage ---
DATABASE_PATH=oraclewatch.db
